# Exemplo de overrides de banco para o rollout de HML.
#
# Uso:
#   set -a
#   source infraestrutura/prod/ecs/hml-db-overrides.example.env
#   set +a
#   bash infraestrutura/prod/ecs/rollout_hml_service.sh --service identidade --image <imagem>
#
# Se nada for exportado, o script usa os defaults atuais de HML:
# - host compartilhado: eickrono-hml-postgres.cdu8yi4qkl16.sa-east-1.rds.amazonaws.com
# - auth banco: keycloak_hml
# - identidade banco: eickrono_identidade_hml
# - thimisu banco: eickrono_thimisu_hml

export HML_SHARED_DB_HOST=eickrono-hml-postgres.cdu8yi4qkl16.sa-east-1.rds.amazonaws.com
export HML_SHARED_DB_PORT=5432
export HML_SHARED_DB_PASSWORD_SECRET_ARN=arn:aws:secretsmanager:sa-east-1:531708494702:secret:rds!db-7df15f56-c831-40b7-be42-ebd935108b06-22Dwvf:password::

export AUTH_KC_DB_HOST="${HML_SHARED_DB_HOST}"
export AUTH_KC_DB_PORT="${HML_SHARED_DB_PORT}"
export AUTH_KC_DB_NAME=keycloak_hml
export AUTH_KC_DB_USERNAME=eickrono_admin
export AUTH_KC_DB_PASSWORD_SECRET_ARN="${HML_SHARED_DB_PASSWORD_SECRET_ARN}"

export IDENTIDADE_DB_HOST="${HML_SHARED_DB_HOST}"
export IDENTIDADE_DB_PORT="${HML_SHARED_DB_PORT}"
export IDENTIDADE_DB_NAME=eickrono_identidade_hml
export IDENTIDADE_DB_USERNAME=eickrono_admin
export IDENTIDADE_DB_PASSWORD_SECRET_ARN="${HML_SHARED_DB_PASSWORD_SECRET_ARN}"

export THIMISU_DB_HOST="${HML_SHARED_DB_HOST}"
export THIMISU_DB_PORT="${HML_SHARED_DB_PORT}"
export THIMISU_DB_NAME=eickrono_thimisu_hml
export THIMISU_DB_USERNAME=eickrono_admin
export THIMISU_DB_PASSWORD_SECRET_ARN="${HML_SHARED_DB_PASSWORD_SECRET_ARN}"
