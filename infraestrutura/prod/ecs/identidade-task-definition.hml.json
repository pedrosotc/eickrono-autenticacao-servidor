{
  "family": "identidade-hml",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::531708494702:role/eickrono-hml-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::531708494702:role/eickrono-hml-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "identidade",
      "image": "531708494702.dkr.ecr.sa-east-1.amazonaws.com/eickrono-identidade-servidor:hml-20260426-09",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8081,
          "hostPort": 8081,
          "protocol": "tcp"
        },
        {
          "containerPort": 8443,
          "hostPort": 8443,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "hml" },
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:postgresql://eickrono-hml-postgres.cdu8yi4qkl16.sa-east-1.rds.amazonaws.com:5432/eickrono_identidade_hml" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "eickrono_admin" },
        { "name": "SPRING_FLYWAY_SCHEMAS", "value": "identidade_hml" },
        { "name": "SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA", "value": "identidade_hml" },
        { "name": "SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI", "value": "https://oidc-hml.eickrono.store/realms/eickrono" },
        { "name": "SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI", "value": "https://oidc-hml.eickrono.store/realms/eickrono/protocol/openid-connect/certs" },
        { "name": "SEGURANCA_MTLS_HABILITADO", "value": "true" },
        { "name": "SEGURANCA_MTLS_PORTA_INTERNA", "value": "8443" },
        { "name": "SEGURANCA_MTLS_KEYSTORE_ARQUIVO", "value": "file:/app/seguranca/mtls/api-identidade-eickrono.p12" },
        { "name": "SEGURANCA_MTLS_TRUSTSTORE_ARQUIVO", "value": "file:/app/seguranca/mtls/backchannel-truststore.p12" },
        { "name": "IDENTIDADE_CADASTRO_INTERNO_KEYCLOAK_URL_BASE", "value": "http://auth-hml-interno.hml.eickrono.internal:8080" },
        { "name": "IDENTIDADE_CADASTRO_INTERNO_KEYCLOAK_REALM", "value": "eickrono" },
        { "name": "IDENTIDADE_CADASTRO_INTERNO_KEYCLOAK_ADMIN_USERNAME", "value": "admin" },
        { "name": "IDENTIDADE_SESSAO_INTERNA_KEYCLOAK_URL_BASE", "value": "http://auth-hml-interno.hml.eickrono.internal:8080" },
        { "name": "IDENTIDADE_SESSAO_INTERNA_KEYCLOAK_REALM", "value": "eickrono" },
        { "name": "IDENTIDADE_SESSAO_INTERNA_KEYCLOAK_CLIENT_ID", "value": "app-flutter-hml" },
        { "name": "INTEGRACAO_PERFIL_URL_BASE", "value": "https://thimisu-backend-hml-interno.hml.eickrono.internal:8443" },
        { "name": "INTEGRACAO_PERFIL_JWT_INTERNO_URL_BASE", "value": "http://auth-hml-interno.hml.eickrono.internal:8080" },
        { "name": "INTEGRACAO_PERFIL_JWT_INTERNO_REALM", "value": "eickrono" },
        { "name": "INTEGRACAO_PERFIL_JWT_INTERNO_CLIENT_ID", "value": "autenticacao-servidor" },
        { "name": "IDENTIDADE_CADASTRO_EMAIL_FORNECEDOR", "value": "smtp" },
        { "name": "IDENTIDADE_CADASTRO_EMAIL_REMETENTE", "value": "info@eickrono.com" },
        { "name": "IDENTIDADE_CADASTRO_EMAIL_NOME_APLICACAO", "value": "Eickrono HML" },
        { "name": "SPRING_MAIL_HOST", "value": "smtp.mail.me.com" },
        { "name": "SPRING_MAIL_PORT", "value": "587" },
        { "name": "SPRING_MAIL_SMTP_AUTH", "value": "true" },
        { "name": "SPRING_MAIL_SMTP_STARTTLS_ENABLE", "value": "true" }
      ],
      "secrets": [
        { "name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:rds!db-7df15f56-c831-40b7-be42-ebd935108b06-22Dwvf:password::" },
        { "name": "EICKRONO_INTERNAL_SECRET", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/eickrono-internal-secret-rbAreo" },
        { "name": "SEGURANCA_MTLS_KEYSTORE_SENHA", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/mtls-keystore-password-2Ix8LB" },
        { "name": "SEGURANCA_MTLS_TRUSTSTORE_SENHA", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/mtls-truststore-password-1oGP18" },
        { "name": "IDENTIDADE_CADASTRO_INTERNO_KEYCLOAK_ADMIN_PASSWORD", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/keycloak-admin-password-sZBgPa" },
        { "name": "INTEGRACAO_PERFIL_JWT_INTERNO_CLIENT_SECRET", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/keycloak/client-autenticacao-servidor-secret-SPH1fM" },
        { "name": "EICKRONO_PASSWORD_PEPPER", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/eickrono-password-pepper-MjMlBO" },
        { "name": "IDENTIDADE_DEVICE_TOKEN_SECRET", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/identidade/device-token-secret-YaQScJ" },
        { "name": "IDENTIDADE_CODIGO_TOKEN_SECRET", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/identidade/codigo-token-secret-Yh8g7q" },
        { "name": "SPRING_MAIL_USERNAME", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/identidade/smtp-username-eWzE4f" },
        { "name": "SPRING_MAIL_PASSWORD", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/identidade/smtp-password-thPtVl" }
      ],
      "mountPoints": [
        {
          "sourceVolume": "mtls-artifacts",
          "containerPath": "/app/seguranca/mtls",
          "readOnly": true
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hml/identidade",
          "awslogs-region": "sa-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "mtls-artifacts",
      "efsVolumeConfiguration": {
          "fileSystemId": "fs-0edf45a03e2c64caa",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
            "accessPointId": "fsap-020a3308f01ba16b7",
          "iam": "ENABLED"
        }
      }
    }
  ]
}
