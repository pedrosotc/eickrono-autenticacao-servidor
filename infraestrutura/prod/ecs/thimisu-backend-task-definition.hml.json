{
  "family": "thimisu-backend-hml",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::531708494702:role/eickrono-hml-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::531708494702:role/eickrono-hml-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "thimisu-backend",
      "image": "531708494702.dkr.ecr.sa-east-1.amazonaws.com/eickrono-thimisu-backend:hml-20260426-01",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8082,
          "hostPort": 8082,
          "protocol": "tcp"
        },
        {
          "containerPort": 8443,
          "hostPort": 8443,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "hml" },
        { "name": "SERVER_PORT", "value": "8082" },
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:postgresql://eickrono-hml-postgres.cdu8yi4qkl16.sa-east-1.rds.amazonaws.com:5432/eickrono_thimisu_hml" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "eickrono_admin" },
        { "name": "SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA", "value": "thimisu_hml" },
        { "name": "SPRING_FLYWAY_SCHEMAS", "value": "thimisu_hml" },
        { "name": "SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI", "value": "https://oidc-hml.eickrono.store/realms/eickrono" },
        { "name": "SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI", "value": "https://oidc-hml.eickrono.store/realms/eickrono/protocol/openid-connect/certs" },
        { "name": "SEGURANCA_MTLS_HABILITADO", "value": "true" },
        { "name": "SEGURANCA_MTLS_PORTA_INTERNA", "value": "8443" },
        { "name": "SEGURANCA_MTLS_KEYSTORE_ARQUIVO", "value": "file:/app/seguranca/mtls/thimisu-backend.p12" },
        { "name": "SEGURANCA_MTLS_TRUSTSTORE_ARQUIVO", "value": "file:/app/seguranca/mtls/backchannel-truststore.p12" },
        { "name": "INTEGRACAO_AUTENTICACAO_URL_BASE", "value": "https://id-hml-interno.hml.eickrono.internal:8443" },
        { "name": "INTEGRACAO_AUTENTICACAO_JWT_INTERNO_URL_BASE", "value": "http://auth-hml-interno.hml.eickrono.internal:8080" },
        { "name": "INTEGRACAO_AUTENTICACAO_JWT_INTERNO_REALM", "value": "eickrono" },
        { "name": "INTEGRACAO_AUTENTICACAO_JWT_INTERNO_CLIENT_ID", "value": "thimisu-backend" }
      ],
      "secrets": [
        { "name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:rds!db-7df15f56-c831-40b7-be42-ebd935108b06-22Dwvf:password::" },
        { "name": "SEGURANCA_MTLS_KEYSTORE_SENHA", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/mtls-keystore-password-2Ix8LB" },
        { "name": "SEGURANCA_MTLS_TRUSTSTORE_SENHA", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/mtls-truststore-password-1oGP18" },
        { "name": "INTEGRACAO_AUTENTICACAO_JWT_INTERNO_CLIENT_SECRET", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/keycloak/client-thimisu-backend-secret-PtNk7S" },
        { "name": "EICKRONO_INTERNAL_SECRET", "valueFrom": "arn:aws:secretsmanager:sa-east-1:531708494702:secret:/eickrono/hml/shared/eickrono-internal-secret-rbAreo" }
      ],
      "mountPoints": [
        {
          "sourceVolume": "mtls-artifacts",
          "containerPath": "/app/seguranca/mtls",
          "readOnly": true
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hml/thimisu-backend",
          "awslogs-region": "sa-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "mtls-artifacts",
      "efsVolumeConfiguration": {
          "fileSystemId": "fs-0edf45a03e2c64caa",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
            "accessPointId": "fsap-020a3308f01ba16b7",
          "iam": "ENABLED"
        }
      }
    }
  ]
}
