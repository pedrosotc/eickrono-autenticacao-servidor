#
# Exemplo local para substituir o MailHog por iCloud Mail
# usando um dominio customizado no iCloud+ (ex.: info@eickrono.com).
# O login SMTP autentica a conta iCloud primaria; o remetente continua sendo
# o endereco customizado configurado nessa conta.
#
# Copie os valores desejados para infraestrutura/dev/.env
# e nunca comite a senha de app real.
#

IDENTIDADE_CADASTRO_EMAIL_FORNECEDOR=smtp
IDENTIDADE_CADASTRO_EMAIL_REMETENTE=info@eickrono.com
IDENTIDADE_CADASTRO_EMAIL_RESPONDER_PARA=info@eickrono.com
IDENTIDADE_CADASTRO_EMAIL_NOME_APLICACAO=Thimisu Dev

SPRING_MAIL_HOST=smtp.mail.me.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=pedrosotc@icloud.com
SPRING_MAIL_PASSWORD=cjrr-tplv-hbao-kvsh
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
