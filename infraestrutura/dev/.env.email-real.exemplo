#
# Exemplo local para substituir o MailHog por um SMTP real.
# Copie os valores desejados para infraestrutura/dev/.env
# e nunca comite credenciais reais.
#

IDENTIDADE_CADASTRO_EMAIL_FORNECEDOR=smtp
IDENTIDADE_CADASTRO_EMAIL_REMETENTE=estudiantemeduba@gmail.com
IDENTIDADE_CADASTRO_EMAIL_NOME_APLICACAO=Eickrono Dev

# Gmail pessoal:
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=estudiantemeduba@gmail.com
SPRING_MAIL_PASSWORD=COLE_AQUI_SUA_SENHA_DE_APP
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# Se preferir um SMTP Microsoft/Outlook em vez de Gmail, use por exemplo:
# SPRING_MAIL_HOST=smtp-mail.outlook.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=seu_email@outlook.com
# SPRING_MAIL_PASSWORD=COLE_AQUI_SUA_SENHA_OU_SENHA_DE_APP
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
