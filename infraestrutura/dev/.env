COMPOSE_PROJECT_NAME=eickrono_autenticacao

POSTGRES_DB=eickrono_dev
POSTGRES_USER=eickrono
POSTGRES_PASSWORD=senhaLocalDev
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KC_DB=postgres
KC_PROXY=edge
KEYCLOAK_FEATURES=instagram-broker
EICKRONO_PASSWORD_PEPPER=pepperLocalDevTrocar

KEYCLOAK_IDP_THIMISU_GOOGLE_CLIENT_ID=trocar-google-client-id
KEYCLOAK_IDP_THIMISU_GOOGLE_CLIENT_SECRET=trocar-google-client-secret
KEYCLOAK_IDP_THIMISU_APPLE_CLIENT_ID=trocar-apple-client-id
KEYCLOAK_IDP_THIMISU_APPLE_CLIENT_SECRET_JWT=trocar-apple-client-secret-jwt
KEYCLOAK_IDP_THIMISU_FACEBOOK_APP_ID=trocar-facebook-app-id
KEYCLOAK_IDP_THIMISU_FACEBOOK_APP_SECRET=trocar-facebook-app-secret
KEYCLOAK_IDP_THIMISU_LINKEDIN_CLIENT_ID=trocar-linkedin-client-id
KEYCLOAK_IDP_THIMISU_LINKEDIN_CLIENT_SECRET=trocar-linkedin-client-secret
KEYCLOAK_IDP_THIMISU_INSTAGRAM_APP_ID=trocar-instagram-app-id
KEYCLOAK_IDP_THIMISU_INSTAGRAM_APP_SECRET=trocar-instagram-app-secret
KEYCLOAK_IDP_THIMISU_X_CLIENT_ID=trocar-x-client-id
KEYCLOAK_IDP_THIMISU_X_CLIENT_SECRET=trocar-x-client-secret
KEYCLOAK_CLIENT_THIMISU_BACKEND_SECRET=CHANGE_ME
KEYCLOAK_CLIENT_AUTENTICACAO_SERVIDOR_SECRET=CHANGE_ME
KEYCLOAK_CLIENT_SERVIDOR_AUTORIZACAO_SECRET=CHANGE_ME

OIDC_ISSUER_URI=https://oidc-dev.eickrono.online/realms/eickrono
OIDC_JWKS_URI=http://servidor-autorizacao:8080/realms/eickrono/protocol/openid-connect/certs
MTLS_CERT_PATH=/certificados/dev-eickrono.p12
MTLS_CERT_SENHA=senhaCertificadoDev
API_IDENTIDADE_PORT=8081
API_IDENTIDADE_MTLS_PORT=18481
API_CONTAS_PORT=8082
API_IDENTIDADE_DEBUG_PORT=5005
API_CONTAS_DEBUG_PORT=5006
THIMISU_API_MTLS_PORT=18483

IDENTIDADE_DEVICE_TOKEN_SECRET=local-device-token-secret
IDENTIDADE_CODIGO_TOKEN_SECRET=local-codigo-secret
EICKRONO_INTERNAL_SECRET=local-internal-secret
IDENTIDADE_SESSAO_INTERNA_KEYCLOAK_CLIENT_ID=app-flutter-local
IDENTIDADE_SESSAO_INTERNA_KEYCLOAK_CLIENT_SECRET=CHANGE_ME
MTLS_KEYSTORE_SENHA=senhaBackchannelDev
MTLS_TRUSTSTORE_SENHA=senhaBackchannelDev
