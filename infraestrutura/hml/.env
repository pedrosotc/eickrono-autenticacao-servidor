COMPOSE_PROJECT_NAME=eickrono_autenticacao_hml

# Configuracoes do PostgreSQL local compartilhado
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
IDENTIDADE_DB_NAME=eickrono_identidade_hml
CONTAS_DB_NAME=eickrono_contas_hml
POSTGRES_USER=eickrono_hml
POSTGRES_PASSWORD=senhaSuperSeguraHml
KEYCLOAK_DB_NAME=keycloak_hml
KEYCLOAK_DB_USER=keycloak_hml
KEYCLOAK_DB_PASSWORD=senhaKeycloakHml

# Configuracoes do Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB=postgres
KC_PROXY=edge
KEYCLOAK_FEATURES=instagram-broker
EICKRONO_PASSWORD_PEPPER=pepperHomologacaoTrocar
KEYCLOAK_FRONTEND_URL=http://localhost:18080

KEYCLOAK_IDP_THIMISU_GOOGLE_CLIENT_ID=trocar-google-client-id
KEYCLOAK_IDP_THIMISU_GOOGLE_CLIENT_SECRET=trocar-google-client-secret
KEYCLOAK_IDP_THIMISU_APPLE_CLIENT_ID=trocar-apple-client-id
KEYCLOAK_IDP_THIMISU_APPLE_CLIENT_SECRET_JWT=trocar-apple-client-secret-jwt
KEYCLOAK_IDP_THIMISU_FACEBOOK_APP_ID=trocar-facebook-app-id
KEYCLOAK_IDP_THIMISU_FACEBOOK_APP_SECRET=trocar-facebook-app-secret
KEYCLOAK_IDP_THIMISU_LINKEDIN_CLIENT_ID=trocar-linkedin-client-id
KEYCLOAK_IDP_THIMISU_LINKEDIN_CLIENT_SECRET=trocar-linkedin-client-secret
KEYCLOAK_IDP_THIMISU_INSTAGRAM_APP_ID=trocar-instagram-app-id
KEYCLOAK_IDP_THIMISU_INSTAGRAM_APP_SECRET=trocar-instagram-app-secret

# Certificados mTLS (autoassinado)
MTLS_CERT_PATH=/certificados/hml-cliente.p12
MTLS_CERT_SENHA=senhaCertificadoHml
MTLS_KEYSTORE_SENHA=senhaBackchannelHml
MTLS_TRUSTSTORE_SENHA=senhaBackchannelHml

# APIs
KEYCLOAK_PORT=18080
API_IDENTIDADE_PORT=18081
API_IDENTIDADE_MTLS_PORT=19481
API_CONTAS_PORT=18082
API_IDENTIDADE_DEBUG_PORT=5005
API_CONTAS_DEBUG_PORT=5006
THIMISU_API_MTLS_PORT=19483
OIDC_ISSUER_URI=http://localhost:18080/realms/eickrono
OIDC_JWKS_URI=http://host.docker.internal:18080/realms/eickrono/protocol/openid-connect/certs
EICKRONO_INTERNAL_SECRET=internalSecretHomologacaoTrocar
IDENTIDADE_DEVICE_TOKEN_SECRET=hml-device-token-secret
IDENTIDADE_CODIGO_TOKEN_SECRET=hml-codigo-secret
IDENTIDADE_SESSAO_INTERNA_KEYCLOAK_CLIENT_ID=app-flutter-hml
